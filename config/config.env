# 复制为 config/config.env 后按需修改（勿提交）:
#   cp config/config.env.example config/config.env
#
# 本文件两类键：
#   1) 安装器选项 — 仅 setup.sh 各阶段读取，不会写入系统环境
#   2) 环境变量 — 阶段 07 写入 ~/.config/environment.d/ 或 /etc/environment.d/
#      规则：匹配 ^[A-Z_][A-Z0-9_]*= 且不在「安装器选项」列表中的键

# ── APT 镜像 ─────────────────────────────────────────────
# tuna | official
APT_MIRROR=tuna
APT_UPGRADE=1

# ── 输入法（阶段 03）──────────────────────────────────
# 1=安装 packages-extras.txt 中的 fcitx5 相关包并下载词库
INSTALL_FCITX5=1

# ── Git（阶段 08）──────────────────────────────────────
GIT_USER_NAME=example
GIT_USER_EMAIL=example@gmail.com

# ── Node / nvm / nrm（阶段 05）────────────────────────
NODE_VERSION=22
NODE_VERSION_EXTRA=18
NRM_REGISTRY=tencent
# 空格分隔的额外 npm 全局包；默认仅安装 nrm
NPM_GLOBAL_PACKAGES=

# ── Java / Maven（阶段 05）────────────────────────────
JAVA_17_IDENTIFIER=17.0.14-tem
JAVA_21_IDENTIFIER=21.0.6-tem
INSTALL_MAVEN=1

# ── Docker（阶段 05）──────────────────────────────────
INSTALL_DOCKER=1

# ── 环境变量写入范围（阶段 07）────────────────────────
# user   → ~/.config/environment.d/99-dotfiles.conf
# system → /etc/environment.d/99-dotfiles.conf（需 sudo）
ENV_SCOPE=user

# ── 自定义环境变量（阶段 07 会导出）──────────────────
# 示例（取消注释并填写）:
# MY_API_BASE=https://api.example.com
# DATABASE_URL=postgresql://localhost:5432/app
