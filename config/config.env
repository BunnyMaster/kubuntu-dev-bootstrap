# 安装器各阶段读取的选项（按需修改后提交或保留本地变更）

# ── APT 镜像 ─────────────────────────────────────────────
# tuna | official
APT_MIRROR=tuna
APT_UPGRADE=1

# ── 输入法（阶段 08）──────────────────────────────────
# 1=安装 packages-fcitx5.txt 中的 fcitx5 包；词库下载需单独确认
INSTALL_FCITX5=1

# ── Git（阶段 06）──────────────────────────────────────
GIT_USER_NAME=example
GIT_USER_EMAIL=example@gmail.com

# ── Node / nvm / nrm（阶段 04）────────────────────────
NODE_VERSION=22
NODE_VERSION_EXTRA=18
NRM_REGISTRY=tencent
# 空格分隔的额外 npm 全局包；默认仅安装 nrm
NPM_GLOBAL_PACKAGES=

# ── Java / Maven（阶段 04）────────────────────────────
JAVA_DEFAULT_VERSION=21
INSTALL_JAVA_17=1
MAVEN_VERSION=3.9.9
INSTALL_MAVEN=1

# ── Docker（阶段 04）──────────────────────────────────
INSTALL_DOCKER=1

# ── 环境变量写入范围（阶段 07）────────────────────────
# user   → ~/.config/environment.d/99-dotfiles.conf
# system → /etc/environment.d/99-dotfiles.conf（需 sudo）
ENV_SCOPE=user
